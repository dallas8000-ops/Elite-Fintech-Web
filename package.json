{
  "name": "elite-fintech-systems",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["apps/web"],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:backend": "cd apps/backend && python manage.py runserver 8000",
    "migrate": "cd apps/backend && python manage.py migrate",
    "seed": "cd apps/backend && python manage.py seed_demo",
    "test:backend": "cd apps/backend && python manage.py test",
    "smoke": "cd apps/backend && python manage.py seed_demo && python scripts/smoke_live.py",
    "automation:platinum": "cd apps/backend && python scripts/automation_platinum_upgrade.py",
    "check": "npm run check:backend && npm run check:web",
    "check:backend": "cd apps/backend && python scripts/self_check.py",
    "check:web": "npm run build -w apps/web",
    "check:live": "cd apps/backend && python scripts/self_check.py --live"
  }
}
