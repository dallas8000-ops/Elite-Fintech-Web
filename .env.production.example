# Production environment — copy to .env before docker compose up

SECRET_KEY=generate-a-long-random-string-here
DEBUG=False
POSTGRES_PASSWORD=strong-password-here

# Your public URLs (after domain is linked)
CLIENT_URL=https://app.yourdomain.co.za
ALLOWED_HOSTS=api.yourdomain.co.za,app.yourdomain.co.za,localhost
CSRF_TRUSTED_ORIGINS=https://app.yourdomain.co.za,https://api.yourdomain.co.za

# Frontend build-time (use your API URL; empty = same-origin via nginx proxy)
VITE_API_URL=
VITE_WS_URL=

# PayFast (SA)
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=True

# Optional Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

PLATFORM_CNAME_TARGET=edge.elitefintech.systems
