DEBUG=True
SECRET_KEY=change-me-to-a-long-random-django-secret
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3
CLIENT_URL=http://localhost:5173

# Railway: demo user is auto-seeded when RAILWAY_ENVIRONMENT is set. Set SEED_DEMO=false to skip.
SEED_DEMO=false

# East Africa default (UG, KE, RW, TZ). MARKET=ZA = legacy South Africa only.
MARKET=EA
DEFAULT_COUNTRY=UG

# Daily FX pricing (East Africa) — open.er-api.com, no key required
FX_PRICING_ENABLED=true
FX_API_URL=https://open.er-api.com/v6/latest/USD
FX_STALE_HOURS=24
PRICING_BASE_CURRENCY=usd
USD_PRICE_STARTER=12
USD_PRICE_PRO=35
USD_PRICE_ENTERPRISE=120

JWT_ACCESS_MINUTES=10
JWT_REFRESH_DAYS=7

# Auth rate limits (ScopedRateThrottle)
THROTTLE_AUTH_LOGIN=8/min
THROTTLE_AUTH_REGISTER=5/hour
THROTTLE_AUTH_REFRESH=30/min
THROTTLE_BILLING_CHECKOUT=20/min

# Refresh cookie SameSite: Lax for local dev; None for cross-subdomain production (requires HTTPS)
REFRESH_COOKIE_SAMESITE=Lax

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=True

# Flutterwave — Uganda MoMo collections (Phase 1 SACCO pilot)
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
FLUTTERWAVE_ENV=sandbox

PLATFORM_CNAME_TARGET=edge.elitefintech.systems
